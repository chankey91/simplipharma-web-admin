rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Shared helpers -----
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return exists(userDocPath());
    }

    function userRole() {
      return get(userDocPath()).data.role;
    }

    function isAdmin() {
      return hasUserDoc() && (
        userRole() == 'admin' ||
        userRole() == 'Admin'
      );
    }

    function isSalesOfficer() {
      return hasUserDoc() && (
        userRole() == 'salesOfficer' ||
        userRole() == 'SalesOfficer'
      );
    }

    function isOperations() {
      return hasUserDoc() && (
        userRole() == 'operations' ||
        userRole() == 'Operations'
      );
    }

    function isAdminOrSalesOfficer() {
      return isAdmin() || isSalesOfficer();
    }

    function isAdminOrOperations() {
      return isAdmin() || isOperations();
    }

    // Retailer doc exists, is retailer, and lists this user as their Sales Officer (mobile SO flows)
    function retailerAssignedToSO(retailerId) {
      return retailerId is string
        && exists(/databases/$(database)/documents/users/$(retailerId))
        && get(/databases/$(database)/documents/users/$(retailerId)).data.role == 'retailer'
        && get(/databases/$(database)/documents/users/$(retailerId)).data.salesOfficerId == request.auth.uid;
    }

    function orderRetailerId(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data.retailerId;
    }

    function canModifyOrder(orderId) {
      return isAdminOrOperations()
        || orderRetailerId(orderId) == request.auth.uid
        || (isSalesOfficer() && retailerAssignedToSO(orderRetailerId(orderId)));
    }

    /** SO may only adjust delivered-order returns while status is pending_so, without changing core request data. */
    function orderReturnSoImmutableMatch() {
      return request.resource.data.retailerId == resource.data.retailerId
        && request.resource.data.salesOfficerId == resource.data.salesOfficerId
        && request.resource.data.orderId == resource.data.orderId
        && request.resource.data.items == resource.data.items
        && request.resource.data.totalRefundAmount == resource.data.totalRefundAmount
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function orderReturnSalesOfficerPendingSoUpdate() {
      return resource.data.salesOfficerId == request.auth.uid
        && resource.data.status == 'pending_so'
        && orderReturnSoImmutableMatch()
        && (
          request.resource.data.status == 'pending_so'
          || request.resource.data.status == 'pending_admin'
          || (
            request.resource.data.status == 'rejected'
            && request.resource.data.rejectionReason is string
            && request.resource.data.rejectedBy is string
            && request.resource.data.rejectedAt is timestamp
          )
        );
    }

    match /medicines/{medicineId} {
      allow read, write: if signedIn();
    }

    match /banners/{bannerId} {
      allow read, write: if signedIn();
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.retailerId
        || resource.data.salesOfficerId == request.auth.uid
        || isAdminOrOperations()
        || isSalesOfficer()
        || retailerAssignedToSO(resource.data.retailerId)
      );

      // Retailers create their own orders. SO proxy requires assigned retailer + salesOfficerId = actor.
      allow create: if signedIn() && (
        isAdminOrOperations()
        || request.auth.uid == request.resource.data.retailerId
        || (
          isSalesOfficer()
          && retailerAssignedToSO(request.resource.data.retailerId)
          && request.resource.data.retailerId != request.auth.uid
          && request.resource.data.salesOfficerId == request.auth.uid
        )
      );

      allow update: if signedIn() && (
        isAdminOrOperations()
        || (
          resource.data.retailerId == request.auth.uid
          && request.resource.data.retailerId == resource.data.retailerId
        )
        || (
          isSalesOfficer()
          && retailerAssignedToSO(resource.data.retailerId)
          && request.resource.data.retailerId == resource.data.retailerId
        )
      );

      allow delete: if false;

      match /payments/{paymentId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && canModifyOrder(orderId);
        allow delete: if signedIn() && isAdminOrOperations();
      }
    }

    // Tray / operator master lists (admin order processing dropdowns). Any signed-in user may read;
    // writes restricted to admin/operations. Placed early so rules are easy to find when debugging.
    match /trays/{trayId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminOrOperations();
    }
    match /operators/{operatorId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminOrOperations();
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isAdminOrSalesOfficer()
        || isOperations()
        || (
          resource.data.role == 'retailer'
          && resource.data.salesOfficerId == request.auth.uid
        )
      );
      allow write: if signedIn() && (
        request.auth.uid == userId
        || isAdminOrSalesOfficer()
      );
    }

    match /favorites/{favoriteId} {
      allow read, write: if signedIn();
    }

    match /expiry_return_requests/{requestId} {
      allow read: if signedIn() && (
        resource.data.retailerId == request.auth.uid
        || resource.data.salesOfficerId == request.auth.uid
        || isAdminOrOperations()
      );
      allow create: if signedIn() && (
        request.resource.data.retailerId == request.auth.uid
        || (
          isSalesOfficer()
          && request.resource.data.salesOfficerId == request.auth.uid
        )
      );
      allow update: if signedIn() && (
        resource.data.salesOfficerId == request.auth.uid
        || isAdminOrOperations()
      );
      allow delete: if false;
    }

    match /order_return_requests/{requestId} {
      allow read: if signedIn() && (
        resource.data.retailerId == request.auth.uid
        || resource.data.salesOfficerId == request.auth.uid
        || isAdminOrOperations()
      );
      allow create: if signedIn() && (
        request.resource.data.retailerId == request.auth.uid
        || (
          isSalesOfficer()
          && request.resource.data.salesOfficerId == request.auth.uid
        )
      )
        && request.resource.data.status == 'pending_so'
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.salesOfficerId is string
        && request.resource.data.salesOfficerId.size() > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.totalRefundAmount is number;
      allow update: if signedIn() && (
        isAdminOrOperations()
        || orderReturnSalesOfficerPendingSoUpdate()
      );
      allow delete: if false;
    }

    match /credit_notes/{noteId} {
      allow read: if signedIn() && (
        isAdminOrOperations()
        || resource.data.retailerId == request.auth.uid
      );
      allow create, update: if isAdminOrOperations();
      allow delete: if false;
    }

    match /debit_notes/{noteId} {
      allow read: if signedIn() && (
        isAdminOrOperations()
        || resource.data.retailerId == request.auth.uid
      );
      allow create, update: if isAdminOrOperations();
      allow delete: if false;
    }

    match /retailer_registration_requests/{requestId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.salesOfficerId
        || isAdminOrOperations()
      );
      allow create: if signedIn() && (
        isSalesOfficer()
        && request.resource.data.salesOfficerId == request.auth.uid
      );
      allow update: if signedIn() && (
        isAdminOrOperations()
        || (
          isSalesOfficer()
          && resource.data.salesOfficerId == request.auth.uid
          && resource.data.status == 'rejected'
          && request.resource.data.salesOfficerId == resource.data.salesOfficerId
          && request.resource.data.status == 'pending'
        )
      );
      allow delete: if false;
    }

    match /so_visit_logs/{logId} {
      allow read: if signedIn() && (
        resource.data.salesOfficerId == request.auth.uid
        || isAdminOrOperations()
      );
      allow create: if signedIn() && (
        request.resource.data.salesOfficerId == request.auth.uid
        && request.resource.data.retailerId is string
        && request.resource.data.note is string
      );
      allow update, delete: if signedIn() && (
        resource.data.salesOfficerId == request.auth.uid
        || isAdminOrOperations()
      );
    }

    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow write: if isAdminOrOperations();
    }

    match /purchaseInvoices/{invoiceId} {
      allow read: if signedIn() && (isAdminOrOperations() || isSalesOfficer());
      allow write: if isAdminOrOperations();
    }

    match /product_demands/{demandId} {
      allow read: if signedIn() && (
        isAdminOrOperations()
        || resource.data.retailerId == request.auth.uid
        || (
          isSalesOfficer()
          && retailerAssignedToSO(resource.data.retailerId)
        )
      );
      allow create: if signedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.productName is string
        && request.resource.data.productName.size() > 0
        && request.resource.data.manufacturerName is string
        && request.resource.data.manufacturerName.size() > 0
        && request.resource.data.requestedQuantity is number
        && request.resource.data.requestedQuantity >= 1
        && request.resource.data.requestedUnit is string
        && request.resource.data.requestedUnit.size() > 0
        && (!('orderId' in request.resource.data)
          || (request.resource.data.orderId is string && request.resource.data.orderId.size() > 0))
        && (
          request.resource.data.retailerId == request.auth.uid
          || (
            isSalesOfficer()
            && retailerAssignedToSO(request.resource.data.retailerId)
          )
        );
      allow update, delete: if signedIn() && isAdminOrOperations();
    }

    match /bulk_medicine_jobs/{jobId} {
      allow read: if signedIn() && isAdminOrOperations();
      allow create: if signedIn() && isAdminOrOperations()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'queued'
        && request.resource.data.storagePath is string
        && request.resource.data.notifyEmail is string;
      allow update, delete: if false;
    }

    match /users/{userId}/demandCartQueue/{queueId} {
      allow read, delete: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && isAdminOrOperations();
      allow update: if false;
    }

    match /stores/{storeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /inventory/{inventoryId} {
      allow read: if signedIn();
      allow write: if isAdminOrOperations();
    }

    // Daily IST sequence counter for ORD… order document ids (see allocateRetailOrderDocumentId).
    match /orderCounters/{counterId} {
      allow read: if signedIn();
      // Doc id must be YYYYMMDD; seq increments by 1 per write; metadata matches client allocator.
      allow create: if signedIn()
        && counterId.matches('^[0-9]{8}$')
        && request.resource.data.seq is int
        && request.resource.data.seq == 1
        && request.resource.data.tz == 'Asia/Kolkata'
        && request.resource.data.dateKey == counterId;
      allow update: if signedIn()
        && counterId.matches('^[0-9]{8}$')
        && request.resource.data.seq is int
        && request.resource.data.seq == resource.data.seq + 1
        && request.resource.data.dateKey == counterId
        && request.resource.data.dateKey == resource.data.dateKey
        && request.resource.data.tz == 'Asia/Kolkata'
        && request.resource.data.tz == resource.data.tz;
      allow delete: if false;
    }

    // ----- In-app support (Phase 1): one thread per auth uid, ticket queue for admins -----
    match /support_threads/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdminOrOperations());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdminOrOperations());
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && (request.auth.uid == userId || isAdminOrOperations());
        allow create: if signedIn()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() < 12000
          && (
            (request.auth.uid == userId && request.resource.data.from == 'user')
            || (request.auth.uid == userId && request.resource.data.from == 'bot')
            || (isAdminOrOperations() && request.resource.data.from == 'admin')
            || (isAdminOrOperations() && request.resource.data.from == 'system')
          );
        allow update, delete: if false;
      }
    }

    match /support_tickets/{ticketId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isAdminOrOperations()
      );
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail is string
        && request.resource.data.status == 'open'
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() < 500;
      allow update: if signedIn() && (
        isAdminOrOperations()
        || (
          resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.userEmail == resource.data.userEmail
          && request.resource.data.subject == resource.data.subject
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.status in ['open', 'pending_user']
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'lastMessagePreview', 'status'])
        )
      );
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
