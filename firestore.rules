rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Shared helpers -----
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return exists(userDocPath());
    }

    function userRole() {
      return get(userDocPath()).data.role;
    }

    // Match client / legacy data (case variants)
    function isAdmin() {
      return hasUserDoc() && (
        userRole() == 'admin' ||
        userRole() == 'Admin'
      );
    }

    function isSalesOfficer() {
      return hasUserDoc() && (
        userRole() == 'salesOfficer' ||
        userRole() == 'SalesOfficer'
      );
    }

    function isAdminOrSalesOfficer() {
      return isAdmin() || isSalesOfficer();
    }

    // Retailer doc must exist and list this Sales Officer
    function retailerAssignedToSO(retailerId) {
      return exists(/databases/$(database)/documents/users/$(retailerId))
        && get(/databases/$(database)/documents/users/$(retailerId)).data.salesOfficerId == request.auth.uid;
    }

    function orderRetailerId(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data.retailerId;
    }

    function canModifyOrder(orderId) {
      return isAdmin()
        || orderRetailerId(orderId) == request.auth.uid
        || (isSalesOfficer() && retailerAssignedToSO(orderRetailerId(orderId)));
    }

    // ----- Medicines -----
    match /medicines/{medicineId} {
      allow read, write: if signedIn();
    }

    // ----- Banners -----
    match /banners/{bannerId} {
      allow read, write: if signedIn();
    }

    // ----- Orders (tightened update; admin can create) -----
    match /orders/{orderId} {
      allow read: if signedIn();

      // Retailer (self), Sales Officer (assigned retailer), or Admin
      allow create: if signedIn() && (
        isAdmin()
        || request.auth.uid == request.resource.data.retailerId
        || (
          isSalesOfficer()
          && retailerAssignedToSO(request.resource.data.retailerId)
        )
      );

      // Admin any; retailer own order; SO only for assigned retailers; retailerId cannot change except by admin
      allow update: if signedIn() && (
        isAdmin()
        || (
          resource.data.retailerId == request.auth.uid
          && request.resource.data.retailerId == resource.data.retailerId
        )
        || (
          isSalesOfficer()
          && retailerAssignedToSO(resource.data.retailerId)
          && request.resource.data.retailerId == resource.data.retailerId
        )
      );

      // No client-side delete (use status Cancelled or Admin SDK if you need removal)
      allow delete: if false;

      // Payments subcollection (accounting) — same actors as order update
      match /payments/{paymentId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && canModifyOrder(orderId);
        allow delete: if signedIn() && isAdmin();
      }
    }

    // ----- Users -----
    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isAdminOrSalesOfficer()
        || (
          resource.data.role == 'retailer'
          && resource.data.salesOfficerId == request.auth.uid
        )
      );
      allow write: if signedIn() && (
        request.auth.uid == userId
        || isAdminOrSalesOfficer()
      );
    }

    // ----- Favorites -----
    match /favorites/{favoriteId} {
      allow read, write: if signedIn();
    }

    // ----- Expiry return requests -----
    match /expiry_return_requests/{requestId} {
      allow read: if signedIn() && (
        resource.data.retailerId == request.auth.uid
        || resource.data.salesOfficerId == request.auth.uid
        || isAdmin()
      );
      allow create: if signedIn() && (
        request.resource.data.retailerId == request.auth.uid
        || (
          isSalesOfficer()
          && request.resource.data.salesOfficerId == request.auth.uid
        )
      );
      allow update: if signedIn() && (
        resource.data.salesOfficerId == request.auth.uid
        || isAdmin()
      );
      allow delete: if false;
    }

    // ----- Retailer registration requests -----
    match /retailer_registration_requests/{requestId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.salesOfficerId
        || isAdmin()
      );
      allow create: if signedIn() && (
        isSalesOfficer()
        && request.resource.data.salesOfficerId == request.auth.uid
      );
      allow update: if signedIn() && isAdmin();
      allow delete: if false;
    }

    // ----- Vendors (admin web) -----
    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ----- Purchase invoices (admin web) -----
    match /purchaseInvoices/{invoiceId} {
      allow read: if signedIn() && isAdminOrSalesOfficer();
      allow write: if isAdmin();
    }

    // ----- Operations: trays & operators (admin manages; any signed-in client may read for order UI) -----
    match /trays/{trayId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }
    match /operators/{operatorId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ----- Product demands (retailer requests; admin fulfills) -----
    match /product_demands/{demandId} {
      allow read: if signedIn() && (
        isAdmin()
        || resource.data.retailerId == request.auth.uid
      );
      allow create: if signedIn()
        && request.resource.data.retailerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.productName is string
        && request.resource.data.productName.size() > 0
        && request.resource.data.manufacturerName is string
        && request.resource.data.manufacturerName.size() > 0
        && request.resource.data.requestedQuantity is number
        && request.resource.data.requestedQuantity >= 1
        && request.resource.data.requestedUnit is string
        && request.resource.data.requestedUnit.size() > 0;
      allow update, delete: if signedIn() && isAdmin();
    }

    // ----- Bulk medicine import jobs (admin queues Excel; Cloud Function processes) -----
    match /bulk_medicine_jobs/{jobId} {
      allow read: if signedIn() && isAdmin();
      allow create: if signedIn() && isAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'queued'
        && request.resource.data.storagePath is string
        && request.resource.data.notifyEmail is string;
      allow update, delete: if false;
    }

    // ----- Queued cart items from fulfilled product demands -----
    match /users/{userId}/demandCartQueue/{queueId} {
      allow read, delete: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && isAdmin();
      allow update: if false;
    }

    // ----- Legacy / optional collections -----
    match /stores/{storeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /inventory/{inventoryId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ----- Deny everything else -----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
