rules_version = '2';
// Firebase Storage: retailer registration uploads (Sales Officer) must be readable by Admin for review.
// Requires Blaze plan for firestore.* in Storage rules. If deploy fails, use the commented Spark fallback below.
service firebase.storage {
  match /b/{bucket}/o {

    function userRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        (userRole() == 'admin' || userRole() == 'Admin');
    }

    function isSalesOfficer() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        userRole() == 'salesOfficer';
    }

    function isPurchaseOfficer() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        (userRole() == 'purchaseOfficer' || userRole() == 'PurchaseOfficer');
    }

    function isOperations() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        (userRole() == 'operations' || userRole() == 'Operations');
    }

    // Common path prefixes used by mobile apps — add more match blocks if your uploads use another folder name.
    match /retailer_registration/{allPaths=**} {
      allow read: if request.auth != null && (isAdmin() || isSalesOfficer());
      allow write: if request.auth != null && isSalesOfficer();
    }

    match /retailer_registrations/{allPaths=**} {
      allow read: if request.auth != null && (isAdmin() || isSalesOfficer());
      allow write: if request.auth != null && isSalesOfficer();
    }

    match /registration_documents/{allPaths=**} {
      allow read: if request.auth != null && (isAdmin() || isSalesOfficer());
      allow write: if request.auth != null && isSalesOfficer();
    }

    // Retailer UPI payment screenshots (retailer_docs/payment_receipts/*)
    // must be uploadable by authenticated retailers and readable by admin for review.
    match /retailer_docs/payment_receipts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /retailer_docs/{allPaths=**} {
      allow read: if request.auth != null && (isAdmin() || isSalesOfficer());
      allow write: if request.auth != null && isSalesOfficer();
    }

    // Bulk medicine Excel → admin app uploads here, Cloud Function reads it.
    // NOTE: Do not use isAdmin() + Firestore here: Storage rules that call firestore.get()
    // require the Blaze plan; on Spark they fail and uploads get "permission denied".
    // Access control: only this user can write under their uid; creating bulk_medicine_jobs stays admin-only in Firestore.
    match /bulk_medicine_uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Banner images: writes scoped to auth uid — no firestore.get(), so this works on Spark.
    // Mobile app only needs read; URLs may live under banners/images/{uid}/...
    match /banners/images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Other banner paths (legacy flat files, etc.): public read only.
    match /banners/{allPaths=**} {
      allow read: if true;
    }

    // Purchase officer optional invoice attachments before list confirmation
    match /purchase_list_invoices/{listId}/{allPaths=**} {
      allow read: if request.auth != null && (isAdmin() || isOperations() || isPurchaseOfficer());
      allow write: if request.auth != null
        && isPurchaseOfficer()
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    // Paths not matched above are denied by default.
  }
}
